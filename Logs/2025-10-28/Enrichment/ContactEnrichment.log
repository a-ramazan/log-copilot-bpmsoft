2025-10-28 09:18:22,231 [.NET TP Worker] DEBUG Supervisor GetCloudActionsFromDB - CreateContactEnrichResponse: entityId=410006e1-ca4e-4502-a9ec-e54d922d2c00
2025-10-28 09:18:22,231 [.NET TP Worker] DEBUG Supervisor GetCloudActionsFromDB - CreateContactEnrichResponse: sqlText=
SELECT
	NULL "NullAlias"
FROM
	"public"."EnrchTextEntity" "Contact_ETE"
	INNER JOIN "public"."EnrchFoundContact" "EFC" ON ("Contact_ETE"."Id" = "EFC"."EnrchTextEntityId")
WHERE
	"EFC"."ContactId" = @P1
	AND (EXISTS (
SELECT
	NULL "NullAlias"
FROM
	"public"."EnrchTextEntity" "Child_ETE"
	LEFT OUTER JOIN "public"."EnrchProcessedData" "EPD" ON ("Child_ETE"."Hash" = "EPD"."TextEntityHash"
	AND "EPD"."ContactId" = @P2)
WHERE
	"Child_ETE"."ParentId" = "Contact_ETE"."Id"
	AND "EPD"."Id" IS NULL
	AND NOT "Child_ETE"."DuplicationStatus" = 'ExistsInEntity')
	OR EXISTS (
SELECT
	NULL "NullAlias"
FROM
	"public"."EnrchTextEntity" "Parent_ETE"
	LEFT OUTER JOIN "public"."EnrchProcessedData" "EPD" ON ("Parent_ETE"."Hash" = "EPD"."TextEntityHash"
	AND "EPD"."ContactId" = @P3)
WHERE
	"Parent_ETE"."Id" = "Contact_ETE"."ParentId"
	AND "EPD"."Id" IS NULL))
LIMIT 1
